<h1>Créer un nouveau potin 📝</h1>

<% if @gossip.errors.any? %>
  <div class="alert alert-danger">
    <p>Nous n'avons pas réussi à créer le potin pour la raison suivante :</p>
    <ul>
      <% @gossip.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_tag(gossips_path, method: :post, class: "mt-3") do %>
  <div class="mb-3">
    <%= label_tag :title, "Titre du potin" %>
    <%= text_field_tag :title, nil, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= label_tag :content, "Contenu du potin" %>
    <%= text_area_tag :content, nil, class: "form-control" %>
  </div>

  <%= submit_tag "Créer le potin", class: "btn btn-primary" %>
<% end %>
